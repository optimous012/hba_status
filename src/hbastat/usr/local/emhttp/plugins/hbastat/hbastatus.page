require_once('/usr/local/emhttp/plugins/dynamix/include/Wrappers.php');

$hbastat_cfg = parse_plugin_cfg('hbastat', true);

$pluginConfigured = !(empty($hbastat_cfg)
    || !isset($hbastat_cfg['VENDOR'])
    || $hbastat_cfg['VENDOR'] == ""
    || $hbastat_cfg['VENDOR'] == "Change Me");

$visibleControllers = [];
foreach ($hbastat_cfg as $key => $val) {
    if (preg_match('/^SHOWCTRL_(\d+)$/', $key, $m) && (string)$val === '1') {
        $visibleControllers[] = $m[1];
    }
}
sort($visibleControllers, SORT_NUMERIC);

$colStatus = (string)($hbastat_cfg['DISPSTATUS']      ?? '1') === '1';
$colTemp   = (string)($hbastat_cfg['DISPTemperature'] ?? '1') === '1';
$colSmart  = (string)($hbastat_cfg['DISPChkp']        ?? '1') === '1';
$colDrives = (string)($hbastat_cfg['DISPPresent']     ?? '1') === '1'
          || (string)($hbastat_cfg['DISPOptl']        ?? '1') === '1';

$tempWarn = (int)($hbastat_cfg['TEMP_WARN'] ?? 60);
$tempCrit = (int)($hbastat_cfg['TEMP_CRIT'] ?? 70);
$tempFmt  = (string)($hbastat_cfg['TEMPFORMAT'] ?? 'C');

// Build the tile header subtext.
if (!$pluginConfigured) {
    $subtext = 'Please configure HBAStat settings first';
} elseif (empty($visibleControllers)) {
    $subtext = 'No controllers selected';
} else {
    $n = count($visibleControllers);
    $subtext = $n . ' controller' . ($n === 1 ? '' : 's');
}

$header_html = <<<EOT
<tr>
    <td><i class="fa fa-fw fa-close control tile" onclick="dismiss(\$(this))" title="Close Tile"></i>
        <span class="tile-header">
            <span class="tile-header-left">
                <i class="icon-hardware f32"></i>
                <div class="section">
                    <h3 class="tile-header-main">HBA Controllers</h3>
                    <span>{$subtext}</span><br>
                </div>
            </span>
            <span class="tile-header-right">
                <span class="tile-header-right-controls">
                    <a href="/Dashboard/Settings/HBASettings" title="Go to HBA settings">
                        <i class="fa fa-fw fa-cog control"></i>
                    </a>
                    <i class="fa fa-fw fa-chevron-up control openclose" onclick="openClose(\$(this))" title="Show/Hide Content"></i>
                </span>
            </span>
        </span>
    </td>
</tr>
EOT;

$rows_html = '';
if ($pluginConfigured && !empty($visibleControllers)) {
    $colsHtml = '<span class="w26">Controller</span>';
    if ($colStatus) $colsHtml .= '<span class="w18">Status</span>';
    if ($colTemp)   $colsHtml .= '<span class="w18">Temp</span>';
    if ($colSmart)  $colsHtml .= '<span class="w18">SMART</span>';
    if ($colDrives) $colsHtml .= '<span class="w18">Drives</span>';

    $rows_html .= "<tr class=\"header\"><td>{$colsHtml}</td></tr>";

    foreach ($visibleControllers as $cid) {
        $cid_esc = htmlspecialchars($cid);
        $rowParts = [
            "<span class=\"w26\"><i class=\"icon-hardware f14\"></i> <a href=\"/Dashboard/Settings/HBASettings\" title=\"Controller {$cid_esc} settings\">Ctl {$cid_esc} <span class=\"hba-product-{$cid}\"></span></a></span>"
        ];
        if ($colStatus) {
            $rowParts[] = "<span class=\"w18\"><i class=\"fa fa-circle orb hba-status-orb-{$cid} middle\"></i><span class=\"hba-status-text-{$cid}\">&hellip;</span></span>";
        }
        if ($colTemp) {
            $rowParts[] = "<span class=\"w18\"><span class=\"hba-temperature-{$cid}\">&hellip;</span></span>";
        }
        if ($colSmart) {
            $rowParts[] = "<span class=\"w18\"><span class=\"hba-smart-icon-{$cid} fa fa-thumbs-o-up green-text\" style=\"margin-right:6px\"></span><span class=\"hba-smart-text-{$cid}\">&hellip;</span></span>";
        }
        if ($colDrives) {
            $rowParts[] = "<span class=\"w18\"><span class=\"hba-drives-{$cid}\">&hellip;</span></span>";
        }
        $rows_html .= "<tr class=\"updated\"><td>" . implode('', $rowParts) . "</td></tr>";
    }
}

$mytiles['hbastat1']['column2'] = <<<EOT
<tbody title="HBA Controller Information" class="sortable hba-tbody">
{$header_html}
{$rows_html}
</tbody>
EOT;
?>
<style type="text/css">
    @import url("/plugins/hbastat/css/style.css");
</style>
<script type="text/javascript">
    window.HBASTAT_TEMP_FORMAT = "<?=htmlspecialchars($tempFmt, ENT_QUOTES);?>";
    window.HBASTAT_TEMP_WARN   = <?=$tempWarn;?>;
    window.HBASTAT_TEMP_CRIT   = <?=$tempCrit;?>;
</script>
<script type="text/javascript" src="/plugins/hbastat/scripts/hbastat.js"></script>
<script type="text/javascript">
    $(hbastat_status);
    if (<?=$hbastat_cfg['UIREFRESH'] ?? '0';?>) {
        setInterval(hbastat_status, <?=max(abs(_var($display,'refresh',5000)), $hbastat_cfg['UIREFRESHINT'] ?? 5000);?>);
    }
</script>
