$hbastat_cfg = parse_plugin_cfg('hbastat', true);

$pluginConfigured = !(empty($hbastat_cfg) || !isset($hbastat_cfg['VENDOR']) || $hbastat_cfg['VENDOR'] == "" || $hbastat_cfg['VENDOR'] == "Change Me");

// Build the list of controllers to display: any SHOWCTRL_X cfg key set to "1".
$visibleControllers = [];
foreach ($hbastat_cfg as $key => $val) {
    if (preg_match('/^SHOWCTRL_(\d+)$/', $key, $m) && (string)$val === '1') {
        $visibleControllers[] = $m[1];
    }
}
sort($visibleControllers, SORT_NUMERIC);

// Per-controller poller value with fallback to global key, then default "1".
function hba_disp(array $cfg, string $base, string $ctlId, string $default = '1'): string {
    $perCtl = $base . '_' . $ctlId;
    if (isset($cfg[$perCtl]) && $cfg[$perCtl] !== '') {
        return (string)$cfg[$perCtl];
    }
    if (isset($cfg[$base]) && $cfg[$base] !== '') {
        return (string)$cfg[$base];
    }
    return $default;
}

// Rows to render per controller. Each row: [DISP key, label, span class suffix].
$rows = [
    ['DISPSTATUS',      'Vendor / Product',              'vendor-product'],
    ['DISPTemperature', 'Temperature',                   'temperature'],
    ['DISPSTATUS',      'Serial / Firmware',             'serial-firmware'],
    ['DISPPresent',     'Present Drives',                'present'],
    ['DISPMissng',      'Missing Drives',                'missing'],
    ['DISPOptl',        'Optimal Drives',                'optimal'],
    ['DISPDgrd',        'Failed Drives',                 'failed'],
    ['DISPDdff',        'Degraded Drives',               'degraded'],
    ['DISPOnLn',        'Offline Drives',                'offline'],
    ['DISPRbld',        'Rebuild Operations',            'rebuild'],
    ['DISPChky',        'Consistency Check',             'consistency'],
    ['DISPChkp',        'Predictive Failure',            'predictive'],
    ['DISPBlk',         'Background Operations',         'background'],
];
?>
<style type="text/css">
    @import url("/plugins/hbastat/css/style.css");
</style>

<table id='db-box1' class='dash_hbastat dashboard box1' style='display:none'>
    <thead sort='953'><tr class='hidden'><td></td><td colspan='3'></td><td></td></tr></thead>
    <tbody sort='953' class='sortable'>
        <tr>
            <td></td>
            <td class='next' colspan='3'>
                <i class='icon-hardware'></i>
                <div class='section'>HBA Controllers<br>
<?php if (!$pluginConfigured): ?>
                    <span>Please configure HBAStat settings first</span>
<?php elseif (empty($visibleControllers)): ?>
                    <span>No controllers selected — open settings to enable one.</span>
<?php endif; ?>
                </div>
                <i class='fa fa-fw chevron mt0' id='dash_hbastat_toggle' onclick='toggleChevron("dash_hbastat_toggle",0)'></i>
                <a href='/Dashboard/Settings/HBASettings' id='dash_hbastat_settings' title='Go to HBA Statistics settings'><i class='fa fa-fw fa-cog chevron mt0'></i></a>
                <br><br>
            </td>
            <td></td>
        </tr>
<?php if ($pluginConfigured && !empty($visibleControllers)): ?>
<?php foreach ($visibleControllers as $cid): ?>
        <tr class="dash_hbastat_toggle hba-enviro hba-section hba-section-<?=$cid?>">
            <td></td>
            <td colspan="3"><b>Controller <?=htmlspecialchars($cid)?></b></td>
        </tr>
<?php foreach ($rows as $row): list($dispKey, $label, $suffix) = $row; ?>
<?php if (hba_disp($hbastat_cfg, $dispKey, $cid) !== '1') continue; ?>
<?php if ($suffix === 'vendor-product'): ?>
        <tr class="dash_hbastat_toggle hba-enviro hba-row-<?=$cid?>">
            <td></td>
            <td><span class='hba-vendor-<?=$cid?>'></span>&nbsp;<span class='hba-product-<?=$cid?>'></span></td>
            <td></td>
            <td></td>
        </tr>
<?php elseif ($suffix === 'temperature'): ?>
        <tr class="dash_hbastat_toggle hba-enviro hba-row-<?=$cid?>">
            <td></td>
            <td>Temperature</td>
            <td><span class='hba-temperature-<?=$cid?> load'></span></td>
            <td></td>
        </tr>
<?php elseif ($suffix === 'serial-firmware'): ?>
        <tr class="dash_hbastat_toggle hba-enviro hba-row-<?=$cid?>">
            <td></td>
            <td>Serial / Firmware</td>
            <td><span class='hba-serialno-<?=$cid?> load'></span></td>
            <td><span class='hba-firmware-<?=$cid?> load'></span></td>
        </tr>
<?php else: ?>
        <tr class="dash_hbastat_toggle hba-enviro hba-row-<?=$cid?>">
            <td></td>
            <td><?=htmlspecialchars($label)?></td>
            <td><span class='hba-<?=$suffix?>-<?=$cid?> load'></span></td>
            <td></td>
        </tr>
<?php endif; ?>
<?php endforeach; ?>
<?php endforeach; ?>
<?php endif; ?>
    </tbody>
</table>
