require_once '/usr/local/emhttp/plugins/hbastat/lib/Main.php';
require_once '/usr/local/emhttp/plugins/hbastat/lib/Hba.php';

use hbastat\lib\Hba;

function save_ini_file($file, $array) {
   $plugin = "hbastat";

  $res = array();
  foreach($array as $key => $val) {
    if(is_array($val)) {
      $res[] = PHP_EOL."[$key]";
      foreach($val as $skey => $sval) $res[] = "$skey = ".(is_numeric($sval) ? $sval : '"'.$sval.'"');
    } else {
      $res[] = "$key = ".(is_numeric($val) ? $val : '"'.$val.'"');
     }
  }

  /* Write changes to tmp file. */
  file_put_contents($file, implode(PHP_EOL, $res));

  /* Write changes to flash. */
  $file_path = pathinfo($file);
  if ($file_path['extension'] == "cfg") {
    file_put_contents("/boot/config/plugins/".$plugin."/".basename($file), implode(PHP_EOL, $res));
  }
}

function save_cfg($val) {
  save_ini_file("hbastat.cfg", $val) ;
}

$cfg = $hbastat_cfg = parse_plugin_cfg("hbastat", true);

if (count($_POST)) {
  $cfg = NULL ;
  if ($_POST['#apply'] == "_(Apply)_") {
    array_map(function($k, $v) use (&$cfg) { if($k[0] != "#") $cfg[$k] = $v; }, array_keys($_POST), $_POST );
    // Thresholds in the form are in the user's chosen unit; store canonical °C.
    $postFmt = strtoupper((string)($cfg['TEMPFORMAT'] ?? 'C'));
    foreach (['TEMP_WARN', 'TEMP_CRIT'] as $key) {
      if (isset($cfg[$key]) && $cfg[$key] !== '') {
        $val = (int)$cfg[$key];
        if ($postFmt === 'F') {
          $cfg[$key] = (int)round(($val - 32) * 5 / 9);
        }
      }
    }
    save_cfg($cfg);
    $hbastat_cfg = parse_plugin_cfg("hbastat", true);
    unset($_POST) ;
  }
}

// Display thresholds in the chosen unit (cfg always stores °C).
$tempFmt = strtoupper((string)($hbastat_cfg['TEMPFORMAT'] ?? 'C'));
$unitLabel = $tempFmt === 'F' ? '°F' : '°C';
$cToDisplay = function (int $c) use ($tempFmt): int {
    return $tempFmt === 'F' ? (int)round($c * 9 / 5 + 32) : $c;
};
$displayWarn   = $cToDisplay((int)($hbastat_cfg['TEMP_WARN'] ?? 60));
$displayCrit   = $cToDisplay((int)($hbastat_cfg['TEMP_CRIT'] ?? 70));
$placeWarn     = $tempFmt === 'F' ? 140 : 60;
$placeCrit     = $tempFmt === 'F' ? 158 : 70;
$rangeMaxValue = $tempFmt === 'F' ? 392 : 200;

$detected = [];
try {
    $detected = (new Hba($hbastat_cfg))->getInventory();
} catch (Throwable $e) {
    $detected = [];
}
if (empty($detected)) {
    $detected = [
        ['id' => '0', 'model' => 'Controller 0', 'vendor' => 'Unknown'],
        ['id' => '1', 'model' => 'Controller 1', 'vendor' => 'Unknown'],
    ];
}

function hba_show_val(array $cfg, string $ctlId): string {
    $perCtl = 'SHOWCTRL_' . $ctlId;
    return isset($cfg[$perCtl]) && $cfg[$perCtl] !== '' ? (string)$cfg[$perCtl] : '1';
}
?>
<script>
$(function() {
  var $fmt = $('#TEMPFORMAT');
  $fmt.data('previous', $fmt.val());

  $fmt.on('change', function() {
    var newFmt = $(this).val();
    var oldFmt = $(this).data('previous');
    $(this).data('previous', newFmt);
    if (newFmt === oldFmt) return;

    // Update unit labels in the threshold rows so the user sees the new unit
    // even before clicking Apply.
    var newLabel = newFmt === 'F' ? '°F' : '°C';
    $('.hba-temp-unit-label').text(newLabel);

    ['TEMP_WARN', 'TEMP_CRIT'].forEach(function(name) {
      var $input = $('input[name="' + name + '"]');
      var val = parseInt($input.val(), 10);
      if (isNaN(val)) return;
      if (oldFmt === 'C' && newFmt === 'F') {
        $input.val(Math.round(val * 9 / 5 + 32));
      } else if (oldFmt === 'F' && newFmt === 'C') {
        $input.val(Math.round((val - 32) * 5 / 9));
      }
    });
  });
});
</script>

